{
  "expo": {
    "name": "Sudoku Infinite",
    "owner": "aimbotic",
    "slug": "sudoku-reveal",
    "version": "1.0.0",
    "scheme": "sudokureveal",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "ios": {
      "bundleIdentifier": "com.aimbotic.sudokuinfinite",
      "icon": "./assets/apple-icon-sudoku-reveal.png",
      "supportsTablet": false,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "experiments": {
      "baseUrl": "/SudokuReveal"
    },
    "plugins": [
      "expo-router",
      "expo-audio"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2219145b-ae95-4778-be5d-e3ad57ee138c"
      }
    }
  }
}
